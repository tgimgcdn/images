{
  "version": 1,
  "include": ["/*"],
  "exclude": ["/assets/*", "/images/*"],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/functions/[[path]].js"
    },
    {
      "src": "/admin/(.*)",
      "dest": "/functions/[[path]].js"
    },
    {
      "src": "/js/(.*)",
      "dest": "/public/js/$1"
    },
    {
      "src": "/css/(.*)",
      "dest": "/public/css/$1"
    },
    {
      "src": "/admin/login.html",
      "dest": "/public/admin/login.html"
    },
    {
      "src": "/",
      "dest": "/public/index.html"
    },
    {
      "src": "/(.*)",
      "dest": "/functions/[[path]].js"
    }
  ]
} 
