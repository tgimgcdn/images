{
  "version": 1,
  "include": ["/*"],
  "exclude": ["/assets/*", "/images/*"],
  "routes": [
    {
      "pattern": "/api/*",
      "script": "/functions/api/[[path]].js"
    },
    {
      "pattern": "/admin/*",
      "script": "/functions/[[path]].js"
    },
    {
      "pattern": "/*",
      "script": "/functions/[[path]].js"
    }
  ]
} 
