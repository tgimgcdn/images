{
  "version": 1,
  "include": ["/api/*", "/images/*"],
  "exclude": [],
  "routes": [
    {
      "routePath": "/api/:path*",
      "mountPath": "/api",
      "method": "",
      "module": ["api/[[path]].js:onRequest"]
    },
    {
      "routePath": "/images/:path*",
      "mountPath": "/images",
      "method": "",
      "module": ["[[path]].js:onRequest"]
    }
  ],
  "baseURL": "/"
} 
