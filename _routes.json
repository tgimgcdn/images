{
  "version": 1,
  "include": ["/_worker", "/*"],
  "exclude": [],
  "routes": [
    {
      "routePath": "/_worker",
      "mountPath": "/",
      "module": ["_worker.js:onRequest"]
    },
    {
      "routePath": "/api/*",
      "mountPath": "/api",
      "module": ["_worker.js:onRequest"]
    }
  ]
} 
