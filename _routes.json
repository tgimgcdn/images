{
  "version": 1,
  "include": ["/*"],
  "routes": [
    {
      "pattern": "/api/*",
      "script": "/functions/api/[[path]].js"
    },
    {
      "pattern": "/admin/*",
      "script": "/functions/[[path]].js"
    },
    {
      "pattern": "/js/*",
      "script": "/functions/[[path]].js"
    },
    {
      "pattern": "/css/*",
      "script": "/functions/[[path]].js"
    },
    {
      "pattern": "/images/*",
      "script": "/functions/[[path]].js"
    },
    {
      "pattern": "/favicon.ico",
      "script": "/functions/[[path]].js"
    },
    {
      "pattern": "/*",
      "script": "/functions/[[path]].js"
    }
  ]
} 
